import streamlit as st
from lib.pdf_export import export_cv_pdf
from lib.db import get_conn, init_db, get_setting

st.set_page_config(page_title="CV", layout="wide")
st.title("CV (Manual Builder)")
st.caption("Projects + certificates structured. Links look like Word links in the PDF.")

def ss_init(key, default):
    if key not in st.session_state:
        st.session_state[key] = default

def normalize_url(u: str) -> str:
    u = (u or "").strip()
    if not u:
        return ""
    if u.startswith("http://") or u.startswith("https://"):
        return u
    return "https://" + u

def projects_to_bullets(projects):
    lines = []
    for p in projects:
        name = (p.get("name") or "").strip()
        url = normalize_url(p.get("url") or "")
        desc = (p.get("desc") or "").strip()
        if not (name or url or desc):
            continue

        if name and url:
            head = f"• [{name}]({url})"
        elif name:
            head = f"• {name}"
        elif url:
            head = f"• [Project]({url})"
        else:
            head = "• Project"

        lines.append(head)
        if desc:
            lines.append(f"  {desc}")
    return "\n".join(lines).strip()

def certs_to_bullets(certs):
    lines = []
    for c in certs:
        title = (c.get("title") or "").strip()
        issuer = (c.get("issuer") or "").strip()
        when = (c.get("date") or "").strip()
        url = normalize_url(c.get("url") or "")

        if not (title or issuer or when or url):
            continue

        label = title if title else "Certificate"
        if url:
            label = f"[{label}]({url})"

        tail = " | ".join([x for x in [issuer, when] if x])
        if tail:
            lines.append(f"• {label} - {tail}")
        else:
            lines.append(f"• {label}")

    return "\n".join(lines).strip()

# Load profile defaults
